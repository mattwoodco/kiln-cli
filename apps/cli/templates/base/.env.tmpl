# Kiln week {{week_padded}} environment.
# Secrets are injected by docker compose at runtime from your host env vars.

# LLM providers — set these on your host, not in this file.
ANTHROPIC_API_KEY=${ANTHROPIC_API_KEY}
OPENAI_API_KEY=${OPENAI_API_KEY:-}
GOOGLE_AI_KEY=${GOOGLE_AI_KEY:-}

# Proxy URLs the student app should use.
ANTHROPIC_BASE_URL=http://kiln-proxy:9100
OPENAI_BASE_URL=http://kiln-proxy:9101
GOOGLE_AI_BASE_URL=http://kiln-proxy:9102

# Cohort metadata written by scaffold.
KILN_COHORT_ID={{cohort_id}}
KILN_COHORT_NAME={{cohort_name}}
KILN_WEEK={{week}}
KILN_PROJECT_KEY={{project_key}}
