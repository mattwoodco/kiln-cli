# kiln-proxy config — consumed by the Go proxy at startup.
upstreams:
  anthropic:
    port: 9100
    url: https://api.anthropic.com
  openai:
    port: 9101
    url: https://api.openai.com
  google:
    port: 9102
    url: https://generativelanguage.googleapis.com

capture:
  ring_bytes: 33554432 # 32 MiB
  flush_interval_ms: 100
  flush_threshold_bytes: 65536

cohort:
  id: {{cohort_id}}
  name: {{cohort_name}}
  week: {{week}}
