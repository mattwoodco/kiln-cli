# Generated by `kiln scaffold --week {{week_padded}}`.
# Edit freely — Kiln only ever rewrites files under .kiln/ after the first scaffold.

services:
  kiln-proxy:
    build:
      context: ./.kiln/proxy
    container_name: kiln-proxy-week-{{week_padded}}
    environment:
      - ANTHROPIC_API_KEY=${ANTHROPIC_API_KEY}
      - OPENAI_API_KEY=${OPENAI_API_KEY:-}
      - GOOGLE_AI_KEY=${GOOGLE_AI_KEY:-}
    ports:
      - "9100:9100" # anthropic
      - "9101:9101" # openai
      - "9102:9102" # google
    volumes:
      - ./.kiln/harness:/harness
    develop:
      watch:
        - action: rebuild
          path: ./.kiln/proxy

  app:
    build:
      context: .
    container_name: kiln-app-week-{{week_padded}}
    environment:
      - ANTHROPIC_BASE_URL=http://kiln-proxy:9100
      - OPENAI_BASE_URL=http://kiln-proxy:9101
      - GOOGLE_AI_BASE_URL=http://kiln-proxy:9102
    depends_on:
      - kiln-proxy
    develop:
      watch:
        - action: sync
          path: .
          target: /app
          ignore:
            - node_modules/
            - .kiln/
            - .git/
