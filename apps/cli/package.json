{
  "name": "@kiln/cli",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "bin": {
    "kiln": "./bin/run.js"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": ["bin", "dist", "oclif.manifest.json"],
  "oclif": {
    "bin": "kiln",
