  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.88.0",
    "@clack/prompts": "^0.8.2",
    "@kiln/shared": "workspace:*",
    "@oclif/core": "^4.0.33",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@types/bun": "^1.3.12",
    "@types/node": "^22.9.0",
    "typescript": "^5.7.2",
    "vitest": "^4.1.4"
  }
}
