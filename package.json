{
  "name": "kiln",
  "private": true,
  "type": "module",
  "workspaces": ["apps/*", "packages/*"],
  "packageManager": "bun@1.3.1",
  "scripts": {
    "build": "turbo build",
    "test": "turbo test",
    "lint": "turbo lint",
    "typecheck": "turbo typecheck",
    "ci": "bun install --frozen-lockfile && bunx turbo typecheck lint test build --filter='@kiln/*'",
    "ci:regression": "bunx vitest run --project regression --root apps/grading"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "turbo": "^2.3.0",
    "typescript": "^5.7.2"
  }
}
